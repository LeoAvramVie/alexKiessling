# Sanity Configuration
SANITY_STUDIO_PROJECT_ID=vlyuixi5
SANITY_STUDIO_DATASET=production

# Sanity API Write Token (Required for local content migration scripts)
# Generate this under: Sanity Manage > API > Tokens > Add token (Editor/Write permission)
SANITY_WRITE_TOKEN=your_sanity_write_token_here

# GitHub Actions Secrets (Set these in GitHub Repository Settings)
# SFTP_SERVER=ftp.yourdomain.com
# SFTP_USERNAME=your_username
# SFTP_PASSWORD=your_password
# SFTP_PORT=22
